<Project>
	<PropertyGroup>
		<TargetFrameworks>netstandard2.1;net10.0;</TargetFrameworks>
		<NamespacePrefix>ZodSharp</NamespacePrefix>
		<!-- Set project-by-project -->
		<IsPackable>false</IsPackable>
		<ExcludePurviewTelemetry>true</ExcludePurviewTelemetry>
		<ExcludeMSTelemetryExtension>true</ExcludeMSTelemetryExtension>
		<RepositoryUrl>https://github.com/guinhx/ZodSharp</RepositoryUrl>
	</PropertyGroup>

	<PropertyGroup>
		<!--
			- CA1510 is because of .NET Standard, we can't use APIs such as
				ArgumentNullException.ThrowIfNull()
		-->
		<NoWarn>$(NoWarn);CA1031;CA1510;</NoWarn>

		<!-- Disabled for now, looks like the .NET 11 Preview SDK is having a moment -->
		<NoWarn>$(NoWarn);IDE0010;IDE0011;IDE0022;IDE0058;IDE0072;IDE0370;</NoWarn>
	</PropertyGroup>

	<Import Sdk="Purview.DotNetProjectSdk" Project="Sdk.props" />

	<PropertyGroup Condition="'$(IsTestProject)' == 'true'">
		<!-- Test projects aren't executable so we need to remove .NET Standard 2.1 -->
		<TargetFrameworks></TargetFrameworks>
		<TargetFramework>net10.0</TargetFramework>
	</PropertyGroup>

	<PropertyGroup Condition="'$(IsPackable)' == 'true'">
		<Authors>ZodSharp Contributors</Authors>
		<PackageProjectUrl>https://github.com/guinhx/ZodSharp</PackageProjectUrl>
		<RepositoryUrl>https://github.com/guinhx/ZodSharp</RepositoryUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>
</Project>
